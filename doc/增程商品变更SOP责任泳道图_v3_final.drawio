        <!-- ========== 第1行：告警等检测 (y=50) ========== -->
        <mxCell id="n1_1" value="01 操作检测&#xa;1 告警等检测" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="container">
