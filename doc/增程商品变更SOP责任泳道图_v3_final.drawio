          <mxGeometry x="15" y="655" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n7_2" value="[操作步骤]&#xa;**验证配置生效**&#xa;执行 cac_obs_service_bill_download&#xa;参数：bucket-name/timestamp/删除话单=0&#xa;数据源：CAC平台" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFB74D;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="300" y="655" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n7_3" value="[操作验证]&#xa;**核对验证结果**&#xa;过滤DomainId + 增程计费因子&#xa;验证sku（第8位字段）+ 计费因子（第13位字段）&#xa;如CAC返回值未按行输出，粘贴至记事本观察&#xa;数据源：CAC平台 / 脚本执行结果" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="740" y="655" width="720" height="70" as="geometry"/>
