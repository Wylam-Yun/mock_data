        <mxCell id="n4_2" value="[等待/放行]&#xa;等待配置确认完成后进入操作处理&#xa;（可选：grep预验证辅助确认）" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;fontColor=#999999;" vertex="1" parent="container">
          <mxGeometry x="300" y="355" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n4_3" value="[操作验证]&#xa;**增程商品确认**：与研发确认操作类型/DomainId/ProductName/&#xa;ResourceSpecCode/ExtendProductName&#xa;与产品经理确认CBC侧配置完成&#xa;配合人核对grep回显，异常时联系研发" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="740" y="355" width="720" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== 第5行：创建增程商品 (y=455) ========== -->
        <mxCell id="n5_1" value="02 操作处理&#xa;1 创建增程商品" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="container">
          <mxGeometry x="15" y="455" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n5_2" value="[操作步骤]&#xa;**创建增程商品**&#xa;登录CAC → 选择目标集群&#xa;执行 create / obs_oam_cli_execute&#xa;参数：service/create/obsBillExtendProduct/${DomainId}/${ExtendProductName}&#xa;提交任务" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFB74D;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="300" y="455" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n5_3" value="[操作验证]&#xa;**验证配置写入**&#xa;等待5分钟 → 登录CAC → 选择bill组件节点&#xa;grep -A 3 '${DomainId}:${ProductName}' bill_extend_product.json&#xa;配合人查看grep回显，异常时联系研发&#xa;数据源：SRE作业平台" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
