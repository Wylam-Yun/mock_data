        </mxCell>
        <mxCell id="n1_2" value="[等待/放行]&#xa;等待配合人检查通过" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;fontColor=#999999;" vertex="1" parent="container">
          <mxGeometry x="300" y="55" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n1_3" value="[影响分析]&#xa;**告警检测**：未处理告警/SLA≥99.99%/1043006告警/联系oncall&#xa;**拨测检测**：拨测运行状态/异常需恢复&#xa;**容量检测**：未变更节点流量承载&#xa;**核心组件性能**：时延/错误率/流量&#xa;**性能检测**：API请求量/网关流量&#xa;结论：有风险则禁止继续" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="740" y="55" width="720" height="70" as="geometry"/>
        </mxCell>

        <!-- ========== 第2行：变更分析 (y=155) ========== -->
        <mxCell id="n2_1" value="01 操作检测&#xa;2 变更分析" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="container">
          <mxGeometry x="15" y="155" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n2_2" value="[等待/放行]&#xa;等待分析结论" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;fontSize=11;align=center;verticalAlign=middle;fontColor=#999999;" vertex="1" parent="container">
          <mxGeometry x="300" y="155" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n2_3" value="[影响分析]&#xa;**10项分析**：①非标项 ②容量评估 ③版本特性差异 ④API接口变更&#xa;⑤监控/拨测影响 ⑥高危操作 ⑦客户列表 ⑧现网配置检查&#xa;⑨变更前备份 ⑩变更失败分析&#xa;每项需给出处理措施，如中止变更" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="740" y="155" width="720" height="70" as="geometry"/>
        </mxCell>

