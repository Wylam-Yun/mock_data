        </mxCell>
        <mxCell id="n3_3" value="[影响分析]&#xa;**客户影响分析**：用户影响/爆炸半径/大客户影响/风险控制措施&#xa;**验证**：确认时间窗/灰度策略/批次间隔&#xa;风险不可控时发起重大变更评审" style="rounded=10;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="container">
          <mxGeometry x="740" y="255" width="720" height="70" as="geometry"/>
        </mxCell>

